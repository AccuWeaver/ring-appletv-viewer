# Ring Partner API Credentials
RING_CLIENT_ID=your_ring_partner_client_id
RING_CLIENT_SECRET=your_ring_partner_client_secret

# HMAC-SHA256 signing key for account linking verification (base64-encoded)
RING_HMAC_KEY=your_base64_encoded_hmac_key

# Shared API key for tvOS app <-> backend authentication
APP_API_KEY=your_shared_api_key

# Fernet key for encrypting tokens at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=your_fernet_encryption_key

# SQLite database file path (default: ./tokens.db)
DATABASE_PATH=./tokens.db

# Logging level (default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# -------------------------------------------------------------------------
# Ring Adapter Selection (ring-adapter-backend spec)
# -------------------------------------------------------------------------

# Backend adapter: "mock" (default, no Ring credentials needed) or
# "unofficial" (uses the user's personal Ring refresh token).
RING_ADAPTER=mock

# Personal Ring refresh token for RING_ADAPTER=unofficial. Generate with:
#   npx -p ring-client-api ring-auth-cli
# SECURITY: never commit the real value. This .env is git-ignored.
# RING_REFRESH_TOKEN=

# Maximum concurrent Ring SIP sessions the backend will maintain.
RING_MAX_CONCURRENT_STREAMS=2

# Outbound request ceiling to api.ring.com per rolling 60-second window.
RING_API_RATE_LIMIT_PER_MINUTE=60

# MediaMTX endpoints. The defaults match docker-compose service names.
MEDIAMTX_RTSP_URL=rtsp://mediamtx:8554/ring
MEDIAMTX_WHEP_BASE=http://mediamtx:8889

# Public HLS base URL for clients that can't play WebRTC (e.g. the tvOS
# simulator). The host and port are what the app sees, not what the
# backend sees — inside Docker this is still mediamtx:8888, but an app
# running on the host reaches it at localhost:8888.
MEDIAMTX_HLS_PUBLIC_BASE=http://localhost:8888

# go2rtc native Ring → HLS bridge (recommended path for simulator live
# video). When RING_REFRESH_TOKEN_G2R is set, the unofficial adapter's
# create_hls_stream_session routes through go2rtc instead of the
# ring-sip-bridge + mediamtx chain. Generate the wrapped token with:
#   echo "$RING_REFRESH_TOKEN" | uv run python ../scripts/wrap-ring-token.py
# Internal URL is what the backend uses; public URL is what the client
# (tvOS simulator) uses to reach the HLS playlist.
GO2RTC_URL=http://go2rtc:1984
GO2RTC_PUBLIC_URL=http://localhost:1984
# RING_REFRESH_TOKEN_G2R=

# Node.js SIP bridge sidecar URL. Matches the docker-compose service name.
RING_SIP_BRIDGE_URL=http://ring-sip-bridge:3000

# Public URL of the sidecar. The backend returns HLS URLs using this
# prefix when the sidecar is configured to produce HLS directly (the
# recommended simulator path). Override per environment as needed.
RING_SIP_BRIDGE_PUBLIC_URL=http://localhost:3000

# -------------------------------------------------------------------------
# Source routing configuration (ring-adapter-live-media spec)
# -------------------------------------------------------------------------

# Comma-separated ordered list of adapter modes to try (partner, unofficial, mock).
# Falls back to RING_ADAPTER if unset.
RING_ADAPTER_ROUTING=

# -------------------------------------------------------------------------
# Snapshot cache configuration
# -------------------------------------------------------------------------

# Maximum age (seconds) for a snapshot to be considered fresh (served without upstream call)
SNAPSHOT_TTL_FRESH_SECONDS=60

# Maximum age (seconds) for a stale snapshot to still be served when all sources fail
SNAPSHOT_TTL_STALE_SERVE_SECONDS=600

# How often (seconds) the background refresh job runs
SNAPSHOT_REFRESH_INTERVAL_SECONDS=45

# Maximum total bytes for the in-memory snapshot cache (default: 64 MiB)
SNAPSHOT_CACHE_MAX_BYTES=67108864

# -------------------------------------------------------------------------
# Source quarantine configuration
# -------------------------------------------------------------------------

# Number of consecutive upstream failures before a source is quarantined
SOURCE_QUARANTINE_THRESHOLD=3

# Duration (seconds) a source stays quarantined after hitting the threshold
SOURCE_QUARANTINE_SECONDS=60
