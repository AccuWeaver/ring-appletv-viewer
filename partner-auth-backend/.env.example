# Ring Partner API Credentials
RING_CLIENT_ID=your_ring_partner_client_id
RING_CLIENT_SECRET=your_ring_partner_client_secret

# HMAC-SHA256 signing key for account linking verification (base64-encoded)
RING_HMAC_KEY=your_base64_encoded_hmac_key

# Shared API key for tvOS app <-> backend authentication
APP_API_KEY=your_shared_api_key

# Fernet key for encrypting tokens at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=your_fernet_encryption_key

# SQLite database file path (default: ./tokens.db)
DATABASE_PATH=./tokens.db

# Logging level (default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# -------------------------------------------------------------------------
# Ring Adapter Selection (ring-adapter-backend spec)
# -------------------------------------------------------------------------

# Backend adapter: "mock" (default, no Ring credentials needed) or
# "unofficial" (uses the user's personal Ring refresh token).
RING_ADAPTER=mock

# Personal Ring refresh token for RING_ADAPTER=unofficial. Generate with:
#   npx -p ring-client-api ring-auth-cli
# SECURITY: never commit the real value. This .env is git-ignored.
# RING_REFRESH_TOKEN=

# Maximum concurrent Ring SIP sessions the backend will maintain.
RING_MAX_CONCURRENT_STREAMS=2

# Outbound request ceiling to api.ring.com per rolling 60-second window.
RING_API_RATE_LIMIT_PER_MINUTE=60

# MediaMTX endpoints. The defaults match docker-compose service names.
MEDIAMTX_RTSP_URL=rtsp://mediamtx:8554/ring
MEDIAMTX_WHEP_BASE=http://mediamtx:8889

# Node.js SIP bridge sidecar URL. Matches the docker-compose service name.
RING_SIP_BRIDGE_URL=http://ring-sip-bridge:3000
