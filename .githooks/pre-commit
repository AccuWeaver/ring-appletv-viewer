#!/usr/bin/env bash
#
# Pre-commit hook: runs SwiftLint on staged Swift files and swift test.
# Install by running: git config core.hooksPath .githooks

set -euo pipefail

echo "🔍 Running pre-commit checks..."

# ── SwiftLint ────────────────────────────────────────────────────────────────

STAGED_SWIFT_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.swift' || true)

if [ -n "$STAGED_SWIFT_FILES" ]; then
    if command -v swiftlint &> /dev/null; then
        echo "Running SwiftLint on staged Swift files..."
        echo "$STAGED_SWIFT_FILES" | xargs swiftlint lint --strict --quiet
        LINT_EXIT=$?
        if [ $LINT_EXIT -ne 0 ]; then
            echo "❌ SwiftLint found issues. Please fix them before committing."
            exit 1
        fi
        echo "✅ SwiftLint passed."
    else
        echo "⚠️  SwiftLint not installed. Install with: brew install swiftlint"
        echo "   Skipping lint step."
    fi
else
    echo "No staged Swift files — skipping SwiftLint."
fi

# ── Tests ────────────────────────────────────────────────────────────────────

echo "Running swift test..."
if ! swift test --package-path RingAppleTV 2>&1; then
    echo "❌ Tests failed. Please fix failing tests before committing."
    exit 1
fi
echo "✅ Tests passed."

echo "🎉 All pre-commit checks passed."
